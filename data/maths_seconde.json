                        </div>

                        <div class="propriete">
                            <span class="label">Équation Produit Nul</span>
                            <p style="text-align:center; font-size:1.2rem; margin:15px 0;">$A \\times B = 0 \\iff A = 0 \\text{ ou } B = 0$</p>
