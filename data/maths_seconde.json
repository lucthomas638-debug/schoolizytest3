                    formules: [
                        { nom: "Médiane", expression: "Valeur partageant la série en deux groupes de 50%." },
                        { nom: "Écart interquartile", expression: "$Q_3 - Q_1$" }
                    ]
                },
                12: {
                    titre: "Probabilités : Calculer le Hasard",
                    definitions: [
                        { terme: "Univers ($\\Omega$)", def: "Ensemble de tous les résultats possibles." },
                        { terme: "Événement contraire", def: "Noté $\\bar{A}$, c'est l'ensemble des issues n'appartenant pas à A." }
                    ],
                    formules: [
                        { nom: "Probabilité", expression: "$P(A) = \\frac{\\text{cas favorables}}{\\text{cas possibles}}$" },
                        { nom: "Réunion", expression: "$P(A \\cup B) = P(A) + P(B) - P(A \\cap B)$" }
                    ]
                },
                13: {
