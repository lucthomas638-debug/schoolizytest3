                    ],
                    formules: [
                        { nom: "Vecteur AB", expression: "$\\vec{AB}(x_B - x_A ; y_B - y_A)$" },
                        { nom: "Distance AB", expression: "$AB = \\sqrt{(x_B-x_A)^2 + (y_B-y_A)^2}$" },
                        { nom: "Déterminant", expression: "$det(\\vec{u}, \\vec{v}) = xy' - yx' = 0 \\iff$ colinéaires" }
                    ]
                },
                9: {
                    titre: "Lignes et Droites : Équations Cartésiennes",
