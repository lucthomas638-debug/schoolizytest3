                        { terme: "Factoriser", def: "Transformer une somme en produit." },
                        { terme: "Développer", def: "Transformer un produit en somme." }
                    ],
                    formules: [
                        { nom: "Identités remarquables", expression: "$(a+b)^2 = a^2+2ab+b^2$ ; $(a-b)^2 = a^2-2ab+b^2$ ; $(a-b)(a+b) = a^2-b^2$" },
                        { nom: "Équation produit", expression: "$A \\times B = 0 \\iff A=0 \\text{ ou } B=0$" }
                    ]
                },
                4: {
                    titre: "Initiation aux Fonctions",
                    definitions: [
                        { terme: "Image", def: "Valeur de $y$ obtenue pour un $x$ donné. Notée $f(x)$." },
                        { terme: "Antécédent", def: "Valeur de $x$ qui donne une image $y$ spécifique." }
                    ],
                    formules: [
                        { nom: "Ensemble de définition", expression: "Intervalle des valeurs de $x$ pour lesquelles $f(x)$ est calculable." }
                    ],
                    points_cles: ["L'image se lit sur l'axe des ordonnées.", "Un nombre peut avoir plusieurs antécédents, mais une seule image."]
                },
                5: {
                    titre: "Modélisation Linéaire : Les Fonctions Affines",
                    definitions: [
                        { terme: "Fonction affine", def: "Fonction de la forme $f(x) = ax + b$ représentée par une droite." },
                        { terme: "Ordonnée à l'origine", def: "Valeur de $b$, point où la droite coupe l'axe $y$." }
                    ],
                    formules: [
                        { nom: "Coefficient directeur (a)", expression: "$a = \\frac{f(x_2) - f(x_1)}{x_2 - x_1}$" },
                        { nom: "Sens de variation", expression: "Si $a > 0$ : croissante. Si $a < 0$ : décroissante." }
                    ]
                },
                6: {
                    titre: "Bibliothèque des Fonctions de Référence",
                    definitions: [
                        { terme: "Parabole", def: "Nom de la courbe de la fonction carré ($x^2$)." },
                        { terme: "Hyperbole", def: "Nom de la courbe de la fonction inverse ($1/x$)." }
                    ],
                    formules: [
                        { nom: "Carré", expression: "$f(x) = x^2$ (Toujours positive)" },
