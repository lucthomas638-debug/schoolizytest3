                    definitions: [
                        { terme: "Ensembles", def: "Classification des nombres : $\\mathbb{N}$ (entiers naturels), $\\mathbb{Z}$ (relatifs), $\\mathbb{D}$ (décimaux), $\\mathbb{Q}$ (rationnels) et $\\mathbb{R}$ (réels)." },
                        { terme: "Nombre premier", def: "Nombre entier naturel qui possède exactement deux diviseurs : 1 et lui-même." }
                    ],
                    formules: [
                        { nom: "Parité", expression: "Pair : $2k$ | Impair : $2k+1$ (où $k$ est un entier)." },
                        { nom: "Valeur absolue", expression: "$|x|$ représente la distance entre $x$ et 0. $|x-a|$ est la distance entre $x$ et $a$." }
                    ],
                    points_cles: ["$\\mathbb{N} \\subset \\mathbb{Z} \\subset \\mathbb{D} \\subset \\mathbb{Q} \\subset \\mathbb{R}$.", "Le carré d'un nombre impair est toujours impair."]
                },
                2: {
                    titre: "Techniques de Calcul : Puissances et Racines",
                    definitions: [
                        { terme: "Racine carrée", def: "Pour $a \\ge 0$, $\\sqrt{a}$ est le nombre positif dont le carré vaut $a$." },
                        { terme: "Notation scientifique", def: "Écriture sous la forme $a \\times 10^n$ avec $1 \\le a < 10$." }
                    ],
                    formules: [
                        { nom: "Puissances", expression: "$a^n \\times a^m = a^{n+m}$ ; $(a^n)^m = a^{n \\times m}$ ; $a^{-n} = \\frac{1}{a^n}$" },
                        { nom: "Racines", expression: "$\\sqrt{a \\times b} = \\sqrt{a} \\times \\sqrt{b}$ ; $\\sqrt{\\frac{a}{b}} = \\frac{\\sqrt{a}}{\\sqrt{b}}$" }
                    ],
                    points_cles: ["Attention : $\\sqrt{a+b} \\neq \\sqrt{a} + \\sqrt{b}$", "Priorités opératoires : les puissances sont prioritaires sur la multiplication."]
                },
                3: {
                    titre: "L'Art du Calcul Littéral : Développer et Factoriser",
